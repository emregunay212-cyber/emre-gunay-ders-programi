# Copy this file to .env.local (for `vercel dev`) or set as env vars in Vercel dashboard.

# Admin panel password (set a strong one)
ADMIN_PASSWORD=degistir-beni

# JWT signing secret (generate with: openssl rand -hex 32)
JWT_SECRET=degistir-beni-en-az-32-karakter-uzunlugunda

# Email service (Resend — https://resend.com, free 100/day)
RESEND_API_KEY=re_xxxxx
FROM_EMAIL="BT Ders Programı <onboarding@resend.dev>"

# Web Push VAPID keys (generate with: npx web-push generate-vapid-keys --json)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# App URL (for email/push approval links)
APP_URL=https://emre-gunay-ders-programi.vercel.app

# Admin teacher slug (receives escalation notifications on 30-min timeout)
ADMIN_TEACHER_SLUG=emre

# Optional: cron endpoint auth for manual testing
CRON_SECRET=

# Upstash Redis — automatically injected when you connect the integration to the project.
# Do NOT set manually in production.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
